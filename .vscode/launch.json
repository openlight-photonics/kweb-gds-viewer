{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build",
      "env": {
        "KWEB_GDS_VIEWER_PORT": "8077"
      }
    }
  ]
}
